# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
egg-info/
eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# uv lock file
uv.lock

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.coverage
.coverage.*
.cache
.pytest_cache/
.nox/

# Jupyter Notebook
.ipynb_checkpoints/

# VS Code
.vscode/

# Logs and databases
*.log
*.sqlite3
*.db

# OS files
.DS_Store
Thumbs.db

# Data analysis outputs
*.html
*.pdf
*.png
*.jpg
*.jpeg
*.svg
*.mp4
*.mov

# Environment variables
.env.*

# Ignore local IDE and system files
*.sublime-workspace
*.sublime-project
.idea/

# Dataset files because they are large and should not be tracked in version control
dataset/*